# Per-host build overrides (CMAKE / DEPS_SRC / VERDI_HOME ...). Each machine
# keeps its own; never committed so the tracked command line stays identical.
/local.mk

# Build artifacts — everything lands under the top-level build/ tree
# (build/cmodel, build/verilator, build/vcs)
/build/
Testing/
c_model/Testing/
# Legacy locations (pre build/-tree restructure); keep ignored so stale
# checkouts don't show noise
sim/verilator/obj_dir/
sim/verilator/obj_genamba/
c_model/build/

# Temporary files
*.tmp
*.log

# Co-sim runtime artifacts (per-instance variants since multi-instance DPI refactor)
master_wrap_read_dump*.txt
w_beats_received_

# Editor/tool files
.vscode/

# Codex prompt files
.codex_*.txt

# Per-simulator run outputs (sim/verilator/output, sim/vcs/output)
sim/*/output/
# Legacy run-output location
sim/output/

# Generated tb_top filelist (regenerated from build_config.mk's TB_TOP_SV_SRC
# by both sim flows; bakes in host-absolute paths so it must not be committed)
sim/filelist.f

# Local Python installs (project-local 3.14, ~278 MB total)
/Python/
/specgen/Python/

# Codegraph MCP database
/.codegraph/

# User-local workspace (kept local-only by default; see
# docs/_archive/superpowers/specs/2026-06-07-doc-cleanup-and-rewrite-design.md sec 4)
/dpi_ref/
/issue/

# Image artifacts only referenced by archived material
/docs/image/*.jpg

# Python tooling caches
/.pytest_cache/
__pycache__/
*.py[cod]

# Cross-AI review artifacts (transient; not normative)
/cross-review/
docs/slides/

# Local-only doc references (vendor PDF + markitdown conversion + superseded draft)
/docs/pg037_axi_perf_mon.pdf
/docs/pg037_axi_perf_mon.md
/docs/probe_section_layout_draft.md

# Slide decks (company-master binaries: source template + generated output;
# rebuild the generated one with docs/build_perf_probe_slides.py)
/docs/*.pptx
docs/issue/
