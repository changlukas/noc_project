`timescale 1ns/1ps

`ifndef NI_PARAMS_PKG_SVH
`define NI_PARAMS_PKG_SVH

package ni_params_pkg;

  // AXI parameter defaults
  localparam int unsigned NI_AXI_ID_WIDTH_DFLT   = 8;
  localparam int unsigned NI_AXI_ADDR_WIDTH_DFLT = 64;
  localparam int unsigned NI_AXI_DATA_WIDTH_DFLT = 256;

  // NoC parameter defaults
  localparam int unsigned NI_NOC_NUM_VC_DFLT                = 1;
  localparam int unsigned NI_NOC_FLIT_WIDTH_DFLT            = 408;
  localparam int unsigned NI_NOC_SLAVE_VC_BUFFER_DEPTH_DFLT = 4;

  // Derived parameter defaults
  localparam int unsigned NI_AXI_WSTRB_WIDTH_DFLT = 32;

endpackage

`endif // NI_PARAMS_PKG_SVH
