{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni-spec/ni_packet.schema.json",
  "title": "NoC NI Packet Format Schema",
  "type": "object",
  "required": ["meta", "flit"],
  "additionalProperties": true,

  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$"}
  },

  "properties": {
    "meta": {
      "type": "object",
      "required": ["block", "spec_version"],
      "properties": {
        "block":        {"type": "string"},
        "spec_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "scope":        {"type": "string"}
      }
    },

    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "default", "constraint"],
        "additionalProperties": false,
        "properties": {
          "name":       {"$ref": "#/$defs/identifier"},
          "type":       {"enum": ["int", "bool", "enum"]},
          "default":    {"type": ["integer", "boolean", "string"]},
          "constraint": {"type": "object", "required": ["kind"]}
        }
      }
    },

    "flit": {
      "type": "object",
      "required": ["header_fields", "payload_channels"],
      "additionalProperties": true,
      "properties": {
        "field_widths": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "header_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "width_param"],
            "additionalProperties": true,
            "properties": {
              "name":            {"$ref": "#/$defs/identifier"},
              "width_param":     {"type": "string"},
              "width":           {"type": "integer", "minimum": 0},
              "lsb":             {"type": ["integer", "null"], "minimum": 0},
              "msb":             {"type": ["integer", "null"], "minimum": 0},
              "enabled":         {
                "type": "boolean",
                "default": true,
                "description": "Whether this field is functional (driven by hardware) or padding (stubbed to 0)"
              },
              "encoding":        {
                "type": "object",
                "additionalProperties": {"type": "string"}
              },
              "reserved_values": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "payload_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "network", "payload_width", "fields"],
            "additionalProperties": true,
            "properties": {
              "name":          {"enum": ["AW", "W", "AR", "B", "R"]},
              "network":       {"enum": ["REQ", "RSP"]},
              "payload_width": {"type": "integer", "minimum": 1},
              "fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "additionalProperties": true,
                  "properties": {
                    "name":        {"$ref": "#/$defs/identifier"},
                    "width_param": {"type": "string"},
                    "width":       {"type": "integer", "minimum": 1},
                    "lsb":         {"type": "integer", "minimum": 0},
                    "msb":         {"type": "integer", "minimum": 0}
                  }
                }
              }
            }
          }
        },
        "derived": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 1}
        },
        "route_par_coverage": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
