{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ni-spec/ni_signals.schema.json",
  "title": "NoC NI Signal Interface Schema — top-level only (Task 3.5 clean shape)",
  "type": "object",
  "required": ["$schema_version", "meta", "block_enables", "interfaces"],
  "additionalProperties": false,

  "$defs": {
    "param": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name":            {"type": "string"},
        "type":            {"type": "string"},
        "default":         {"type": "string"},
        "constraint_text": {"type": "string"}
      }
    },
    "signal": {
      "type": "object",
      "description": "Signal entry. Identifier is always pin_name. AXI channel signals use pin_name derived from channel+suffix. NoC signals use pin_name derived from noc_<logical_name>. PP-9: per-pin width is purely symbolic — width_param + width_expr only; resolution against the merged namespace (packet field_widths + interface port_parameters) is the consumer's responsibility.",
      "required": ["width_param", "pin_name"],
      "additionalProperties": false,
      "properties": {
        "width_param": {"type": ["string", "null"], "description": "Parameter name that controls this signal's width. Null for fixed 1-bit signals (no parameter reference)."},
        "direction":   {"enum": ["input", "output"]},
        "pin_name": {
          "type": ["string", "null"],
          "description": "RTL-level concrete pin name (e.g. axi_awvalid_i)"
        },
        "reset_behavior": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "kind": {"enum": ["async-active-low", "sync-active-high", "external_driven"]},
            "value": {"type": "string"},
            "domain": {"type": "string"}
          },
          "required": ["kind"]
        },
        "presence": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {"condition_text": {"type": "string"}}
        },
        "width_expr": {
          "type": ["string", "null"],
          "description": "Width expression (format TBD; validation added in future task)"
        }
      }
    },
    "channel": {
      "type": "object",
      "required": ["name", "direction"],
      "additionalProperties": false,
      "properties": {
        "name":      {"enum": ["AW", "W", "AR", "B", "R"]},
        "direction": {"enum": ["input", "output"]},
        "carrier":   {"enum": ["request", "response"]},
        "signals": {
          "type": "array",
          "items": {"$ref": "#/$defs/signal"}
        }
      }
    }
  },

  "properties": {
    "$schema_version": {
      "type": "string",
      "description": "Schema version identifier (e.g. ni-spec/2.0)"
    },

    "meta": {
      "type": "object",
      "required": ["block", "spec_version"],
      "additionalProperties": true,
      "properties": {
        "block":        {"type": "string"},
        "spec_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "reset_signals": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Legal reset signal names extracted from pin_level_reset.md"
        }
      }
    },

    "block_enables": {
      "type": "array",
      "items": {"$ref": "#/$defs/param"}
    },

    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["block", "name"],
        "additionalProperties": false,
        "properties": {
          "block":        {"enum": ["NMU", "NSU"]},
          "name":         {
            "type": "string",
            "minLength": 1,
            "description": "UPPER_SNAKE_CASE identifier (e.g. AXI_SLAVE_PORT, NOC_REQ_OUT)"
          },
          "direction":    {"type": "string"},
          "protocol":     {"type": "string"},
          "clock":        {"type": "string", "description": "Clock signal name (e.g. aclk_i)"},
          "reset":        {"type": "string", "description": "Reset signal name (e.g. arst_ni)"},
          "channels": {
            "type": "array",
            "description": "AXI / AXI4-Lite only — 5 channels (AW/W/B/AR/R) each with signals[].",
            "items": {"$ref": "#/$defs/channel"}
          },
          "signals": {
            "type": "array",
            "description": "NoC link signals (valid/flit/credit/credit-init). AXI puts signals inside channels[].",
            "items": {"$ref": "#/$defs/signal"}
          },
          "port_parameters": {
            "type": "array",
            "items": {"$ref": "#/$defs/param"}
          }
        }
      }
    }
  }
}
